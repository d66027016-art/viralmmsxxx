datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String         @id @default(uuid())
  name             String
  email            String         @unique
  passwordHash     String
  avatar           String?
  subscription     String         @default("free") // "free", "premium"
  createdAt        DateTime       @default(now())
  watchHistory     WatchHistory[]
  favorites        Favorite[]
  downloads        Download[]
  bookings         Booking[]
}

model Content {
  id           String         @id @default(uuid())
  title        String
  description  String
  category     String
  tags         String         // Comma-separated list
  thumbnail    String         // URL or path
  videoUrl     String         // URL or path
  duration     String         // e.g. "2h 15m" or "45m"
  views        Int            @default(0)
  likes        Int            @default(0)
  qualities    String         @default("1080p,720p") // Comma-separated list
  createdAt    DateTime       @default(now())
  history      WatchHistory[]
  favorites    Favorite[]
  downloads    Download[]
}

model WatchHistory {
  id          String   @id @default(uuid())
  userId      String
  contentId   String
  progress    Float    @default(0.0) // percentage
  lastWatched DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
}

model Favorite {
  id        String  @id @default(uuid())
  userId    String
  contentId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
}

model Download {
  id        String   @id @default(uuid())
  userId    String
  contentId String
  quality   String
  status    String   @default("completed") // "downloading", "completed"
  progress  Int      @default(100)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Girl {
  id           String    @id @default(uuid())
  name         String
  age          Int
  location     String    // e.g. "Mumbai", "Delhi", "Bengaluru"
  category     String    // e.g. "VIP Russian", "Elite Local", "Celebrity"
  ratePerHour  Int       // Pricing in INR hourly
  ratePerDay   Int       // Pricing in INR daily
  avatar       String    // Unsplash profile image URL
  images       String    // Comma-separated list of additional image URLs
  bio          String
  rating       Float     @default(5.0)
  reviewsCount Int       @default(1)
  available    Boolean   @default(true)
  createdAt    DateTime  @default(now())
  bookings     Booking[]
}

model Booking {
  id            String   @id @default(uuid())
  userId        String
  girlId        String
  bookingDate   DateTime
  bookingType   String   @default("hourly") // "hourly" or "daily"
  durationHours Int
  durationDays  Int      @default(0)
  totalPrice    Int
  status        String   @default("pending") // "pending", "confirmed", "completed", "cancelled"
  location      String   // E.g. hotel name or private address
  contactPhone  String
  notes         String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  girl          Girl     @relation(fields: [girlId], references: [id], onDelete: Cascade)
}
